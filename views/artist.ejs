          <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-danger rounded-pill px-4" id="saveMetadataBtn">Guardar Cambios</button>
        </div>
      </form>
    </div>
  </div>
</div>

