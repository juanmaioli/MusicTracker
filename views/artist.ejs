            <label for="inputDeceased" class="form-label text-secondary fw-semibold small">Fallecido (Opcional)</label>
            <input type="text" class="form-control bg-black bg-opacity-50 text-white border-secondary border-opacity-25" id="inputDeceased" placeholder="Ej. 8 de diciembre de 1980" value="<%= artistMetadata['Fallecido'] || '' %>">
          </div>
