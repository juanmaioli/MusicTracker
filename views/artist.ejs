<!-- Modal para Editar Ficha Técnica -->
<div class="modal fade" id="editMetadataModal" tabindex="-1" aria-labelledby="editMetadataModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content bg-dark border-secondary border-opacity-25 rounded-4 shadow-lg text-white">
      <div class="modal-header border-bottom border-secondary border-opacity-10 py-3">
        <h5 class="modal-title fw-bold" id="editMetadataModalLabel">
          <i class="bi bi-pencil-square text-danger me-2"></i>Editar Ficha Técnica
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>
      <form id="editMetadataForm" onsubmit="saveArtistMetadata(event)">
        <div class="modal-body p-4 d-flex flex-column gap-3">
          <div>
            <label for="inputFormedIn" class="form-label text-secondary fw-semibold small">Formado en (Banda / Grupo)</label>
            <input type="text" class="form-control bg-black bg-opacity-50 text-white border-secondary border-opacity-25" id="inputFormedIn" placeholder="Ej. Londres, Reino Unido" value="<%= artistMetadata['Formado en'] || '' %>">
          </div>
          <div>
            <label for="inputBirthDate" class="form-label text-secondary fw-semibold small">Fecha de nacimiento (Solista)</label>
            <input type="text" class="form-control bg-black bg-opacity-50 text-white border-secondary border-opacity-25" id="inputBirthDate" placeholder="Ej. 18 de junio de 1942" value="<%= artistMetadata['Fecha de nacimiento'] || '' %>">
          </div>
          <div>
            <label for="inputBirthPlace" class="form-label text-secondary fw-semibold small">Lugar de nacimiento (Solista)</label>
            <input type="text" class="form-control bg-black bg-opacity-50 text-white border-secondary border-opacity-25" id="inputBirthPlace" placeholder="Ej. Liverpool, Inglaterra" value="<%= artistMetadata['Lugar de nacimiento'] || '' %>">
          </div>
          <div>
            <label for="inputActiveYears" class="form-label text-secondary fw-semibold small">Años de actividad</label>
            <input type="text" class="form-control bg-black bg-opacity-50 text-white border-secondary border-opacity-25" id="inputActiveYears" placeholder="Ej. 1960 – presente" value="<%= artistMetadata['Años de actividad'] || '' %>">
          </div>
