<%- include('partials/header') %>

<%
function formatDuration(ms) {
  if (!ms) return '0:00';
  const minutes = Math.floor(ms / 60000);
  const seconds = Math.floor((ms % 60000) / 1000);
  return minutes + ":" + (seconds < 10 ? '0' : '') + seconds;
}

function formatBiography(text) {
  if (!text) return '<p class="text-secondary m-0">No hay biografía disponible.</p>';
  
  const escaped = text
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#x27;');

  const cleanText = escaped.trim();
  const sentences = cleanText.split(/(?<=\.\s)(?=[A-ZÁÉÍÓÚÑ])/);
  
  if (sentences.length <= 1) {
    return `<p class="bio-paragraph">${cleanText}</p>`;
  }
  
  const paragraphs = [];
  const groupSize = 3;
  for (let i = 0; i < sentences.length; i += groupSize) {
    const group = sentences.slice(i, i + groupSize).join(' ');
    paragraphs.push(`<p class="bio-paragraph">${group}</p>`);
  }
  
  return paragraphs.join('\n');
}

// Parsear metadata del artista al inicio
let artistMetadata = {};
if (artist.metadata) {
  try {
    artistMetadata = JSON.parse(artist.metadata);
  } catch(e) {
    artistMetadata = {};
  }
}
const hasMetadata = Object.keys(artistMetadata).length > 0;
%>

<div class="row g-4">
  <!-- Perfil Lateral -->
  <div class="col-lg-4">
    <div class="glass-card p-4 text-center sticky-lg-top" style="top: 100px; z-index: 1;">
      
      <div class="position-relative mb-4">
        <div id="mainArtistImgWrapper">
          <% if (artist.image) { %>
            <img id="mainArtistImg" src="<%= artist.image %>" alt="<%= artist.name %>" class="img-fluid rounded-4 shadow-lg object-fit-cover w-100" style="max-height: 300px;">
          <% } else { %>
            <div id="mainArtistImgPlaceholder" class="rounded-4 bg-secondary d-flex align-items-center justify-content-center text-dark" style="height: 300px;">
              <i class="bi bi-person-fill display-1"></i>
            </div>
          <% } %>
        </div>
        
        <% const mainFlagPath = getFlagPath(artistMetadata['Lugar de nacimiento'] || artistMetadata['Formado en']); %>
        <% if (mainFlagPath) { %>
          <div class="position-absolute" style="bottom: 15px; right: 15px; z-index: 10;">
            <div class="d-flex align-items-center justify-content-center border border-danger border-2 rounded-circle shadow-lg" style="width: 66px; height: 66px; background-color: rgba(0, 0, 0, 0.5);" title="<%= artistMetadata['Lugar de nacimiento'] || artistMetadata['Formado en'] %>">
              <img src="<%= mainFlagPath %>" alt="Bandera" class="rounded-circle" style="width: 42px; height: 42px; object-fit: cover;" />
            </div>
          </div>
        <% } %>
      </div>

      <h1 class="h2 fw-extrabold mb-1 d-inline-flex align-items-center justify-content-center gap-2 flex-wrap">
        <%= artist.name %>
        <a href="https://www.last.fm/es/music/<%= artist.id %>" target="_blank" class="text-secondary fs-6 fw-normal text-decoration-none hover-danger-link" title="Ver perfil en Last.fm">
          <i class="bi bi-box-arrow-up-right" style="font-size: 0.9rem;" aria-hidden="true"></i>
        </a>
      </h1>
      
      <div class="mb-3 d-flex flex-wrap justify-content-center gap-2">
        <% artist.genresList.forEach(genre => { %>
          <span class="badge bg-danger-subtle text-danger border border-danger border-opacity-10 rounded-pill text-capitalize px-3 py-1.5" style="font-size: 0.8rem; font-weight: 600;"><%= genre %></span>
        <% }) %>
      </div>

      <div class="mb-3 mt-3 text-start bg-dark bg-opacity-25 p-3 rounded-3 border border-secondary border-opacity-10">
        <div class="d-flex flex-column gap-2" id="metadataList" style="font-size: 0.85rem;">
          <% if (!hasMetadata) { %>
            <p id="noMetadataPlaceholder" class="text-secondary small m-0 text-center py-2">Ficha técnica vacía.</p>
          <% } %>
          
          <div id="metaActiveYearsContainer" style="<%= artistMetadata['Años de actividad'] ? '' : 'display: none;' %>">
            <span class="text-secondary fw-semibold">Años de actividad:</span>
            <span id="metaActiveYears" class="text-white-50 ms-1"><%= artistMetadata['Años de actividad'] || '' %></span>
          </div>
          
          <div id="metaFormedInContainer" style="<%= artistMetadata['Formado en'] ? '' : 'display: none;' %>">
            <span class="text-secondary fw-semibold">Formado en:</span>
            <span id="metaFormedIn" class="text-white-50 ms-1"><%= artistMetadata['Formado en'] || '' %></span>
          </div>
          
          <div id="metaBirthDateContainer" style="<%= artistMetadata['Fecha de nacimiento'] ? '' : 'display: none;' %>">
            <span class="text-secondary fw-semibold">Fecha de nacimiento:</span>
            <span id="metaBirthDate" class="text-white-50 ms-1"><%= artistMetadata['Fecha de nacimiento'] || '' %></span>
          </div>
          
          <div id="metaBirthPlaceContainer" style="<%= artistMetadata['Lugar de nacimiento'] ? '' : 'display: none;' %>">
            <span class="text-secondary fw-semibold">Lugar de nacimiento:</span>
            <span id="metaBirthPlace" class="text-white-50 ms-1"><%= artistMetadata['Lugar de nacimiento'] || '' %></span>
          </div>
          
          <div id="metaDeceasedContainer" style="<%= artistMetadata['Fallecido'] ? '' : 'display: none;' %>">
            <span class="text-secondary fw-semibold">Fallecido:</span>
            <span id="metaDeceased" class="text-white-50 ms-1"><%= artistMetadata['Fallecido'] || '' %></span>
          </div>

          <% if (artistMetadata['Miembros'] && Array.isArray(artistMetadata['Miembros']) && artistMetadata['Miembros'].length > 0) { %>
            <div id="metaMembersContainer" class="mt-1">
              <span class="text-secondary fw-semibold">Miembros:</span>
              <ul class="list-unstyled text-white-50 ms-2 mt-1 mb-0 ps-2" style="font-size: 0.8rem; border-left: 2px solid rgba(229, 9, 20, 0.4);">
                <% artistMetadata['Miembros'].forEach(member => { %>
                  <li class="py-0.5"><%= member %></li>
                <% }) %>
              </ul>
            </div>
          <% } %>
        </div>
        
        <button type="button" class="btn btn-sm btn-outline-danger w-100 mt-3 rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#editMetadataModal">
          <i class="bi bi-pencil-square me-1"></i> Editar Ficha
        </button>
      </div>

      <hr class="border-secondary border-opacity-25 my-3">

      <!-- Biografía Scrapeada completa de Last.fm -->
      <div class="mb-4 text-start">
        <h2 class="h6 fw-bold mb-2 d-flex align-items-center"><i class="bi bi-body-text text-danger me-2"></i>Biografía</h2>
        <div class="text-secondary" style="font-size: 0.85rem; line-height: 1.5;">
          <% 
            const bioText = artist.notes || '';
            const words = bioText.trim().split(/\s+/);
            const isLong = words.length > 20;
            const truncatedBio = isLong ? words.slice(0, 20).join(' ') + '...' : bioText;
          %>
          <p class="m-0" style="white-space: pre-line;"><%= truncatedBio %></p>
          <% if (isLong) { %>
            <a href="#" class="text-danger fw-semibold text-decoration-none d-inline-block mt-2 hover-underline" data-bs-toggle="modal" data-bs-target="#bioModal" style="font-size: 0.8rem;">
              Leer más <i class="bi bi-plus-circle align-middle ms-1" style="font-size: 0.75rem;"></i>
            </a>
          <% } %>
        </div>
      </div>




      <!-- Eliminar Artista -->
      <form action="/artists/<%= artist.id %>/delete" method="POST" onsubmit="return confirm('¿Estás seguro de que querés eliminar a este artista de tu base de datos? Esto también borrará sus álbumes y calificaciones.');">
        <button class="btn btn-outline-danger w-100 btn-sm" type="submit">
          <i class="bi bi-trash3 me-1"></i>Dejar de Seguir y Borrar
        </button>
      </form>
    </div>
  </div>

  <!-- Discografía, Canciones y Galería -->
  <div class="col-lg-8">

    <% if (artist.imagesList && artist.imagesList.length > 0) { %>
      <!-- Galería Masonry estilo Pinterest -->
      <div class="glass-card p-4 mb-4">
        <h2 class="h4 fw-bold mb-4 d-flex align-items-center gap-2">
          <i class="bi bi-images text-danger"></i>
          <span>Fotos</span>
          <span class="badge bg-secondary-subtle text-secondary-emphasis rounded-pill fs-6 fw-normal"><%= artist.imagesList.length %></span>
        </h2>
        
        <div class="masonry-grid" id="masonryGrid">
          <div class="masonry-grid-sizer"></div>
          <% artist.imagesList.forEach((img, idx) => { %>
            <div class="masonry-grid-item" onclick="openPhotoLightbox(<%= idx %>)">
              <div class="masonry-card rounded-3 overflow-hidden position-relative shadow-sm">
                <img src="<%= img %>" alt="Foto <%= idx + 1 %> de <%= artist.name %>" class="w-100 h-auto d-block">
                <div class="masonry-overlay d-flex flex-column justify-content-between p-3 position-absolute top-0 start-0 w-100 h-100">
                  <div class="text-end">
                    <a href="<%= img %>" target="_blank" onclick="event.stopPropagation();" class="btn btn-sm btn-dark bg-opacity-75 border-0 rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 32px; height: 32px;" title="Abrir en pestaña nueva">
                      <i class="bi bi-box-arrow-up-right fs-6 text-white"></i>
                    </a>
                  </div>
                  <div class="text-start">
                    <span class="badge bg-dark bg-opacity-75 border border-secondary border-opacity-25 py-1 px-2" style="font-size: 0.75rem;">
                      Foto <%= idx + 1 %>
                    </span>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <!-- Discografía -->
    <div class="glass-card p-4">
      <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
        <h2 class="h3 fw-bold m-0 d-flex align-items-center gap-2">
          <i class="bi bi-disc-fill text-danger"></i>
          <span>Albums</span>
          <span class="badge bg-secondary-subtle text-secondary-emphasis rounded-pill fs-6 fw-normal"><%= albums.length %></span>
        </h2>
        <div class="d-flex gap-2 flex-wrap">
          <form action="/artists/<%= artist.id %>/sync-albums" method="POST" id="syncAlbumsForm">
            <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3 d-flex align-items-center gap-1" id="syncAlbumsBtn">
              <i class="bi bi-arrow-repeat"></i> Actualizar Álbumes
            </button>
          </form>

        </div>
      </div>

      <% if (albums.length === 0) { %>
        <p class="text-secondary text-center py-5">No se encontraron álbumes registrados para este artista.</p>
      <% } else { %>
        <div class="d-flex flex-column gap-3">
          <% albums.forEach((album, index) => { %>
            <div id="album-row-<%= album.id %>" class="d-flex align-items-center justify-content-between p-3 bg-dark bg-opacity-50 text-white border border-secondary border-opacity-25 rounded-4 hover-album-row" style="transition: background-color 0.2s ease, opacity 0.3s ease, transform 0.3s ease;">
              <div class="d-flex align-items-center gap-3 flex-grow-1">
                <% if (album.cover_image && album.cover_image !== 'NO_COVER') { %>
                  <img src="<%= album.cover_image %>" alt="Portada de <%= album.title %>" 
                       class="rounded object-fit-cover shadow-sm album-cover-clickable cursor-zoom" 
                       style="width: 55px; height: 55px;" 
                       data-album-title="<%= album.title %>" 
                       data-album-year="<%= album.release_year || '' %>"
                       data-album-rating="<%= album.user_rating || 0 %>"
                       data-cover-url="<%= album.cover_image %>" 
                       data-tracks="<%= Buffer.from(JSON.stringify(album.tracks)).toString('base64') %>"
                       title="Ver canciones y portada">
                <% } else { %>
                  <div class="rounded bg-secondary d-flex align-items-center justify-content-center text-dark shadow-sm album-cover-clickable cursor-zoom" 
                       style="width: 55px; height: 55px;" 
                       data-album-title="<%= album.title %>" 
                       data-album-year="<%= album.release_year || '' %>"
                       data-album-rating="<%= album.user_rating || 0 %>"
                       data-cover-url="" 
                       data-tracks="<%= Buffer.from(JSON.stringify(album.tracks)).toString('base64') %>"
                       title="Ver canciones">
                    <i class="bi bi-music-note fs-4"></i>
                  </div>
                <% } %>

                <div class="album-cover-clickable cursor-zoom"
                     data-album-title="<%= album.title %>" 
                     data-album-year="<%= album.release_year || '' %>"
                     data-album-rating="<%= album.user_rating || 0 %>"
                     data-cover-url="<%= album.cover_image && album.cover_image !== 'NO_COVER' ? album.cover_image : '' %>" 
                     data-tracks="<%= Buffer.from(JSON.stringify(album.tracks)).toString('base64') %>"
                     title="Ver canciones y portada">
                  <h3 class="h6 fw-bold m-0 text-white hover-underline"><%= album.title %> <%= album.release_year ? `· ${album.release_year}` : '' %></h3>
                </div>

                <a href="#" 
                   class="hover-spotify-link d-inline-flex align-items-center" 
                   title="Escuchar <%= album.title %> en Spotify"
                   onclick="event.preventDefault(); openSpotify('<%= artist.name %> <%= album.title %>');">
                  <i class="bi bi-spotify fs-5"></i>
                </a>
              </div>

              <!-- Calificación de Álbum Fija -->
              <div class="ms-3 d-flex align-items-center gap-3">
                <div class="d-flex align-items-center gap-1 fs-5" style="user-select: none;" title="Calificación: <%= album.user_rating %> de 5 estrellas">
                  <% for (let i = 1; i <= 5; i++) { %>
                    <span class="px-1" style="font-size: 1.25rem; color: <%= i <= album.user_rating ? '#ffc107' : '#6c757d' %>;">
                      <%= i <= album.user_rating ? '★' : '☆' %>
                    </span>
                  <% } %>
                </div>
                <% if (!album.user_rating || album.user_rating === 0) { %>
                  <button type="button" class="btn btn-link link-secondary p-0 hover-text-danger-link delete-album-btn" 
                          data-album-id="<%= album.id %>" 
                          data-artist-id="<%= artist.id %>"
                          title="Borrar álbum sin calificar" style="line-height: 1;">
                    <i class="bi bi-trash3 fs-5"></i>
                  </button>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</div>

<style>
  .hover-underline:hover {
    text-decoration: underline !important;
  }
  .hover-danger-link {
    transition: color 0.15s ease-in-out;
  }
  .hover-danger-link:hover {
    color: var(--brand-color) !important;
  }
  .hover-text-danger-link {
    color: #6c757d !important;
    transition: color 0.15s ease-in-out, transform 0.15s ease-in-out;
  }
  .hover-text-danger-link:hover {
    color: var(--brand-color) !important;
    transform: scale(1.15);
  }
  .accordion-button::after {
    filter: invert(1);
  }
  .hover-track-row:hover {
    background-color: rgba(255, 255, 255, 0.02) !important;
  }
  .hover-heart:hover {
    color: #dc3545 !important;
    transform: scale(1.15);
    transition: transform 0.2s ease, color 0.2s ease;
  }
  .animate-pop {
    display: inline-block;
    animation: pop 0.3s ease;
  }
  @keyframes pop {
    0% { transform: scale(1); }
    50% { transform: scale(1.3); }
    100% { transform: scale(1); }
  }
  .accordion-button:not(.collapsed) {
    background-color: transparent;
    color: white;
  }
  
  /* Scrollbar estético para el div de la Bio */
  .style-scrollbar::-webkit-scrollbar {
    width: 6px;
  }
  .style-scrollbar::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.03);
    border-radius: 10px;
  }
  .style-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.15);
    border-radius: 10px;
  }
  .style-scrollbar::-webkit-scrollbar-thumb:hover {
    background: var(--brand-color);
  }

  /* Pinterest Masonry Layout */
  .masonry-grid {
    width: 100%;
    margin: 0 auto;
  }
  
  /* Por defecto en móviles: 2 columnas */
  .masonry-grid-sizer,
  .masonry-grid-item {
    width: calc((100% - 15px) / 2);
  }
  
  @media (min-width: 768px) {
    .masonry-grid-sizer,
    .masonry-grid-item {
      width: calc((100% - 30px) / 3); /* 3 columnas */
    }
  }
  
  @media (min-width: 1200px) {
    .masonry-grid-sizer,
    .masonry-grid-item {
      width: calc((100% - 60px) / 5); /* 5 columnas */
    }
  }
  
  .masonry-grid-item {
    float: left;
    margin-bottom: 15px;
  }
  
  .masonry-card {
    cursor: pointer;
    background-color: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: transform 0.25s cubic-bezier(0.165, 0.84, 0.44, 1), box-shadow 0.25s cubic-bezier(0.165, 0.84, 0.44, 1);
  }
  .masonry-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.4);
    border-color: rgba(229, 9, 20, 0.3);
  }
  .masonry-card img {
    transition: filter 0.25s ease;
  }
  .masonry-card:hover img {
    filter: brightness(0.85);
  }
  .masonry-overlay {
    opacity: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0) 40%, rgba(0,0,0,0) 60%, rgba(0,0,0,0.6) 100%);
    transition: opacity 0.25s ease;
  }
  .masonry-card:hover .masonry-overlay {
    opacity: 1;
  }
  .cursor-zoom {
    cursor: zoom-in;
  }

  /* Estilos premium para biografías */
  .bio-paragraph {
    margin-bottom: 1.25rem;
    text-align: justify;
    color: rgba(255, 255, 255, 0.8);
  }
  .bio-paragraph:first-of-type::first-letter {
    font-size: 3.2rem;
    font-weight: 800;
    float: left;
    line-height: 1;
    margin-right: 0.6rem;
    margin-top: 0.15rem;
    color: var(--brand-color);
    text-shadow: 0 0 12px rgba(229, 9, 20, 0.35);
  }

  /* Efecto hover premium para el botón de Spotify */
  .hover-spotify-link {
    color: #1db954 !important;
    transition: transform 0.2s ease, color 0.2s ease;
  }
  .hover-spotify-link:hover {
    color: #1ed760 !important;
    transform: scale(1.2) rotate(8deg);
  }

  /* Estilos de alto contraste para el enlace externo y botones del Lightbox */
  .lightbox-external-link, .lightbox-action-btn {
    color: rgba(255, 255, 255, 0.95) !important;
    font-weight: 500;
    transition: color 0.15s ease-in-out;
  }
  .lightbox-external-link:hover, .lightbox-action-btn:hover {
    color: var(--brand-color) !important;
    text-decoration: underline !important;
  }
  .lightbox-action-btn {
    border: none;
    background: transparent;
    padding: 0;
  }

  /* Desenfoque de fondo premium para el modal del Lightbox */
  #photoLightboxModal {
    backdrop-filter: blur(8px);
    background-color: rgba(0, 0, 0, 0.4);
  }
</style>

<script>
  // Formatear duración en el cliente (JS)
  function formatDuration(ms) {
    if (!ms) return '0:00';
    const minutes = Math.floor(ms / 60000);
    const seconds = Math.floor((ms % 60000) / 1000);
    return minutes + ":" + (seconds < 10 ? '0' : '') + seconds;
  }

  // Intentar abrir la app nativa de Spotify con fallback a versión web
  function openSpotify(query) {
    const spotifyUri = `spotify:search:${encodeURIComponent(query)}`;
    const webUrl = `https://open.spotify.com/search/${encodeURIComponent(query)}`;
    const start = Date.now();

    // 1. Redireccionar hacia el esquema URI de Spotify
    window.location.href = spotifyUri;

    // 2. Fallback a la web si pasan 1.2 segundos sin que la página pierda el foco
    const fallbackTimer = setTimeout(() => {
      if (!document.hidden && (Date.now() - start) < 2000) {
        window.open(webUrl, '_blank');
      }
    }, 1200);

    // 3. Cancelar fallback si el navegador se minimiza o pierde foco
    const handleVisibility = () => {
      if (document.hidden) {
        clearTimeout(fallbackTimer);
      }
    };
    document.addEventListener('visibilitychange', handleVisibility, { once: true });
  }

  // Lógica del Lightbox de fotos Masonry
  let currentPhotoIndex = 0;
  let artistImages = [];
  <% if (artist.imagesList) { %>
    artistImages = <%- JSON.stringify(artist.imagesList) %>;
  <% } %>
  let photoLightboxModalInstance = null;

  function openPhotoLightbox(index) {
    currentPhotoIndex = index;
    const imgUrl = artistImages[currentPhotoIndex];
    
    const lightboxImg = document.getElementById('lightboxImg');
    const indexLabel = document.getElementById('lightboxIndexLabel');
    const externalLink = document.getElementById('lightboxExternalLink');
    if (!lightboxImg || !indexLabel) return;
    
    lightboxImg.src = imgUrl;
    indexLabel.textContent = `Foto ${currentPhotoIndex + 1} de ${artistImages.length}`;
    if (externalLink) externalLink.href = imgUrl;
    
    if (!photoLightboxModalInstance) {
      const modalEl = document.getElementById('photoLightboxModal');
      photoLightboxModalInstance = new bootstrap.Modal(modalEl);
      
      // Cerrar modal al hacer clic en cualquier zona vacía (fuera de la imagen y de los botones)
      modalEl.addEventListener('click', (e) => {
        const isClickOnInteractive = e.target.closest('#lightboxImg') || 
                                     e.target.closest('#lightboxPrevBtn') || 
                                     e.target.closest('#lightboxNextBtn') ||
                                     e.target.closest('#lightboxIndexLabel') ||
                                     e.target.closest('#lightboxExternalLink') ||
                                     e.target.closest('.rounded-pill');
        if (!isClickOnInteractive) {
          photoLightboxModalInstance.hide();
        }
      });
    }
    
    photoLightboxModalInstance.show();
  }

  function navigateLightbox(direction) {
    if (artistImages.length <= 1) return;
    
    const lightboxImg = document.getElementById('lightboxImg');
    const indexLabel = document.getElementById('lightboxIndexLabel');
    const externalLink = document.getElementById('lightboxExternalLink');
    if (!lightboxImg || !indexLabel) return;
    
    currentPhotoIndex = (currentPhotoIndex + direction + artistImages.length) % artistImages.length;
    const nextImgUrl = artistImages[currentPhotoIndex];
    
    lightboxImg.style.opacity = '0';
    setTimeout(() => {
      lightboxImg.src = nextImgUrl;
      indexLabel.textContent = `Foto ${currentPhotoIndex + 1} de ${artistImages.length}`;
      if (externalLink) externalLink.href = nextImgUrl;
      lightboxImg.style.opacity = '1';
    }, 150);
  }

  async function setAsMainArtistImage() {
    const lightboxImg = document.getElementById('lightboxImg');
    const setBtn = document.getElementById('setMainImageBtn');
    const setBtnText = document.getElementById('setMainImageBtnText');
    if (!lightboxImg || !setBtn || !setBtnText) return;
    
    const imageUrl = lightboxImg.getAttribute('src');
    if (!imageUrl) return;
    
    setBtn.disabled = true;
    const originalText = setBtnText.textContent;
    setBtnText.textContent = 'Estableciendo...';
    
    try {
      const response = await fetch(`/artists/<%= artist.id %>/set-image`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify({ imageUrl })
      });
      
      const result = await response.json();
      if (result.success) {
        const imgWrapper = document.getElementById('mainArtistImgWrapper');
        if (imgWrapper) {
          let mainImg = document.getElementById('mainArtistImg');
          if (mainImg) {
            mainImg.src = result.imageUrl;
          } else {
            imgWrapper.innerHTML = `<img id="mainArtistImg" src="\${result.imageUrl}" alt="<%= artist.name %>" class="img-fluid rounded-4 shadow-lg object-fit-cover w-100" style="max-height: 300px;">`;
          }
        }
        
        setBtnText.textContent = '¡Foto principal establecida!';
        setTimeout(() => {
          setBtnText.textContent = originalText;
          setBtn.disabled = false;
        }, 2000);
      } else {
        alert('Error al establecer la imagen: ' + (result.error || 'Ocurrió un error inesperado.'));
        setBtnText.textContent = originalText;
        setBtn.disabled = false;
      }
    } catch (err) {
      console.error('Error al establecer la imagen principal:', err);
      alert('Error de red al establecer la imagen.');
      setBtnText.textContent = originalText;
      setBtn.disabled = false;
    }
  }

  // Teclado para navegación de fotos y de grid anterior
  document.addEventListener('keydown', (e) => {
    const photoModalEl = document.getElementById('photoLightboxModal');
    const isPhotoModalOpen = photoModalEl && photoModalEl.classList.contains('show');
    
    if (isPhotoModalOpen) {
      if (e.key === 'ArrowRight') {
        e.preventDefault();
        navigateLightbox(1);
      } else if (e.key === 'ArrowLeft') {
        e.preventDefault();
        navigateLightbox(-1);
      }
    }
  });

  // Inicializar Masonry tras cargar las imágenes
  document.addEventListener('DOMContentLoaded', () => {
    const grid = document.querySelector('#masonryGrid');
    if (grid) {
      imagesLoaded(grid, () => {
        const msnry = new Masonry(grid, {
          itemSelector: '.masonry-grid-item',
          columnWidth: '.masonry-grid-sizer',
          percentPosition: true,
          gutter: 15
        });
      });
    }
  });

  // Modal para visualización de portadas de álbumes y canciones
  document.addEventListener('DOMContentLoaded', () => {
    const coverModalElement = document.getElementById('coverModal');
    if (coverModalElement) {
      const coverModal = new bootstrap.Modal(coverModalElement);
      const coverModalImg = document.getElementById('coverModalImg');
      const coverModalImgContainer = document.getElementById('coverModalImgContainer');
      const coverModalLabel = document.getElementById('coverModalLabel');
      const tracksTableBody = document.getElementById('coverModalTracksTableBody');

      document.querySelectorAll('.album-cover-clickable').forEach(img => {
        img.addEventListener('click', (e) => {
          e.stopPropagation();
          const coverUrl = img.dataset.coverUrl;
          const albumTitle = img.dataset.albumTitle;
          const albumYear = img.dataset.albumYear;
          const albumRating = parseInt(img.dataset.albumRating || '0', 10);
          const tracksDataRaw = img.dataset.tracks;
          
          // Establecer la imagen de portada
          if (coverUrl) {
            coverModalImg.src = coverUrl;
            coverModalImgContainer.style.display = 'block';
          } else {
            coverModalImg.src = '';
            coverModalImgContainer.style.display = 'none';
          }

          // Establecer título con año y calificación
          coverModalLabel.textContent = albumTitle;
          if (albumYear) {
            const yearSpan = document.createElement('span');
            yearSpan.className = 'text-secondary fs-6 fw-normal ms-2';
            yearSpan.textContent = `(${albumYear})`;
            coverModalLabel.appendChild(yearSpan);
          }
          if (albumRating > 0) {
            const starsContainer = document.createElement('span');
            starsContainer.className = 'ms-2 d-inline-flex align-items-center gap-1 fs-6';
            starsContainer.style.userSelect = 'none';
            for (let i = 1; i <= 5; i++) {
              const starSpan = document.createElement('span');
              starSpan.style.color = i <= albumRating ? '#ffc107' : '#6c757d';
              starSpan.textContent = i <= albumRating ? '★' : '☆';
              starsContainer.appendChild(starSpan);
            }
            coverModalLabel.appendChild(starsContainer);
          }

          // Cargar canciones
          tracksTableBody.innerHTML = '';
          if (tracksDataRaw) {
            try {
              // Decodificar Base64 de forma robusta con caracteres UTF-8 usando TextDecoder
              const binaryString = atob(tracksDataRaw);
              const bytes = new Uint8Array(binaryString.length);
              for (let i = 0; i < binaryString.length; i++) {
                bytes[i] = binaryString.charCodeAt(i);
              }
              const decoder = new TextDecoder('utf-8');
              const decodedData = decoder.decode(bytes);
              const tracks = JSON.parse(decodedData);

              if (tracks && tracks.length > 0) {
                tracks.forEach(track => {
                  const tr = document.createElement('tr');
                  tr.className = 'hover-track-row';
                  
                  const duration = formatDuration(track.duration_ms);
                  const isFav = track.is_favorite === 1;
                  
                  tr.innerHTML = `
                    <td class="text-secondary">${track.track_number}</td>
                    <td class="fw-medium text-white-50">${track.title}</td>
                    <td class="text-end text-secondary">${duration}</td>
                    <td class="text-center">
                      <button type="button" class="btn btn-link p-0 border-0 text-decoration-none fav-btn" data-track-id="${track.id}" aria-label="${isFav ? 'Quitar de favoritos' : 'Agregar a favoritos'}">
                        ${isFav 
                          ? '<i class="bi bi-heart-fill text-danger fs-5 animate-pop"></i>' 
                          : '<i class="bi bi-heart text-secondary fs-5 hover-heart"></i>'
                        }
                      </button>
                    </td>
                  `;
                  
                  // Añadir el listener para marcar favorito vía AJAX dentro del modal
                  const favBtn = tr.querySelector('.fav-btn');
                  favBtn.addEventListener('click', async (btnEvent) => {
                    btnEvent.stopPropagation();
                    try {
                      const response = await fetch(`/tracks/${track.id}/favorite`, {
                        method: 'POST',
                        headers: {
                          'Accept': 'application/json'
                        }
                      });
                      const result = await response.json();
                      if (result.success) {
                        track.is_favorite = result.is_favorite;
                        // Guardar de vuelta en el dataset codificándolo robustamente en Base64 con UTF-8
                        const encoder = new TextEncoder();
                        const utf8Bytes = encoder.encode(JSON.stringify(tracks));
                        let binary = '';
                        const len = utf8Bytes.byteLength;
                        for (let i = 0; i < len; i++) {
                          binary += String.fromCharCode(utf8Bytes[i]);
                        }
                        img.dataset.tracks = btoa(binary);
                        
                        if (result.is_favorite === 1) {
                          favBtn.setAttribute('aria-label', 'Quitar de favoritos');
                          favBtn.innerHTML = '<i class="bi bi-heart-fill text-danger fs-5 animate-pop"></i>';
                        } else {
                          favBtn.setAttribute('aria-label', 'Agregar a favoritos');
                          favBtn.innerHTML = '<i class="bi bi-heart text-secondary fs-5 hover-heart"></i>';
                        }
                      }
                    } catch (err) {
                      console.error('Error al actualizar favorito:', err);
                    }
                  });

                  tracksTableBody.appendChild(tr);
                });
              } else {
                tracksTableBody.innerHTML = '<tr><td colspan="4" class="text-secondary text-center py-4">No hay canciones registradas para este álbum.</td></tr>';
              }
            } catch (err) {
              console.error('Error al parsear canciones:', err);
              tracksTableBody.innerHTML = '<tr><td colspan="4" class="text-danger text-center py-4">Error al cargar la lista de canciones.</td></tr>';
            }
          } else {
            tracksTableBody.innerHTML = '<tr><td colspan="4" class="text-secondary text-center py-4">No hay canciones registradas para este álbum.</td></tr>';
          }

          coverModal.show();
        });
      });
    }

    // Spinner de carga para la sincronización de álbumes
    const syncForm = document.getElementById('syncAlbumsForm');
    const syncBtn = document.getElementById('syncAlbumsBtn');
    if (syncForm && syncBtn) {
      syncForm.addEventListener('submit', () => {
        syncBtn.disabled = true;
        syncBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> Sincronizando...';
      });
    }
    // Borrado asíncrono de álbumes sin calificar (sin confirmación y sin recargar)
    document.querySelectorAll('.delete-album-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const albumId = btn.dataset.albumId;
        const artistId = btn.dataset.artistId;
        
        try {
          const response = await fetch(`/artists/${artistId}/albums/${albumId}/delete`, {
            method: 'POST',
            headers: {
              'Accept': 'application/json'
            }
          });
          const result = await response.json();
          if (result.success) {
            const row = document.getElementById(`album-row-${albumId}`);
            if (row) {
              row.style.opacity = '0';
              row.style.transform = 'scale(0.95)';
              setTimeout(() => {
                row.remove();
                
                // Actualizar contador del badge
                const badge = document.querySelector('.h3 .badge');
                if (badge) {
                  const currentCount = parseInt(badge.textContent, 10);
                  if (!isNaN(currentCount) && currentCount > 0) {
                    badge.textContent = currentCount - 1;
                  }
                }
              }, 300);
            }
          }
        } catch (err) {
          console.error('Error al borrar álbum de forma asíncrona:', err);
        }
      });
    });
  });

  async function saveArtistMetadata(event) {
    event.preventDefault();
    const saveBtn = document.getElementById('saveMetadataBtn');
    if (!saveBtn) return;
    
    saveBtn.disabled = true;
    saveBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> Guardando...';
    
    const formedIn = document.getElementById('inputFormedIn').value;
    const birthDate = document.getElementById('inputBirthDate').value;
    const birthPlace = document.getElementById('inputBirthPlace').value;
    const activeYears = document.getElementById('inputActiveYears').value;
    const deceased = document.getElementById('inputDeceased').value;
    
    try {
      const response = await fetch(`/artists/<%= artist.id %>/metadata`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify({ formedIn, birthDate, birthPlace, activeYears, deceased })
      });
      
      const result = await response.json();
      if (result.success) {
        window.location.reload();
      } else {
        alert('Error al guardar los cambios: ' + (result.error || 'Ocurrió un error inesperado.'));
        saveBtn.disabled = false;
        saveBtn.textContent = 'Guardar Cambios';
      }
    } catch (err) {
      console.error('Error al guardar la metadata:', err);
      alert('Error de red al intentar guardar los datos.');
      saveBtn.disabled = false;
      saveBtn.textContent = 'Guardar Cambios';
    }
  }
</script>

