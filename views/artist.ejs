<!-- Modal Lightbox de Fotos de la Galería -->
<div class="modal fade" id="photoLightboxModal" tabindex="-1" aria-labelledby="photoLightboxLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-xl">
    <div class="modal-content bg-transparent border-0 shadow-none text-white">
      <div class="modal-body p-0 position-relative text-center d-flex flex-column align-items-center justify-content-center">
        <!-- Botón para cerrar -->
        <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Cerrar" style="z-index: 1050; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.8));"></button>
        
        <!-- Contenedor de Imagen con transición -->
        <div class="d-flex align-items-center justify-content-between w-100" style="max-height: 85vh;">
          <!-- Flecha izquierda -->
          <button class="btn btn-link text-white p-2 border-0" id="lightboxPrevBtn" onclick="navigateLightbox(-1)" style="font-size: 2.5rem; text-shadow: 0 2px 4px rgba(0,0,0,0.8); z-index: 1040;">
            <i class="bi bi-chevron-left"></i>
          </button>
          
          <div class="mx-auto overflow-hidden rounded-4 shadow-lg border border-secondary border-opacity-10 bg-black bg-opacity-75" style="max-width: 80%; max-height: 80vh;">
            <img id="lightboxImg" src="" alt="Foto ampliada del artista" class="img-fluid object-fit-contain" style="max-height: 80vh; transition: opacity 0.2s ease;">
          </div>
          
          <!-- Flecha derecha -->
          <button class="btn btn-link text-white p-2 border-0" id="lightboxNextBtn" onclick="navigateLightbox(1)" style="font-size: 2.5rem; text-shadow: 0 2px 4px rgba(0,0,0,0.8); z-index: 1040;">
            <i class="bi bi-chevron-right"></i>
          </button>
        </div>
        
        <!-- Info inferior -->
        <div class="mt-3 bg-dark bg-opacity-75 py-2 px-4 rounded-pill border border-secondary border-opacity-25 d-flex align-items-center gap-3" style="backdrop-filter: blur(10px);">
          <span id="lightboxIndexLabel" class="text-white fw-medium fs-6">Foto 1 de 10</span>
          <span class="text-white-50">|</span>
          <a href="" id="lightboxExternalLink" target="_blank" class="lightbox-external-link text-decoration-none d-inline-flex align-items-center gap-1 small" title="Abrir en pestaña nueva">
            <i class="bi bi-box-arrow-up-right"></i>
            <span>Abrir en pestaña nueva</span>
          </a>
          <span class="text-white-50">|</span>
          <button id="setMainImageBtn" onclick="setAsMainArtistImage()" class="lightbox-action-btn text-decoration-none d-inline-flex align-items-center gap-1 small" title="Establecer como foto principal">
            <i class="bi bi-image"></i>
            <span id="setMainImageBtnText">Usar como foto principal</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

