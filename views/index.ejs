<%- include('partials/header') %>



<div class="row">
  <div class="col-12">
    <div class="glass-card p-4">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h4 fw-bold m-0"><i class="bi bi-music-note-list text-danger me-2"></i>Tus Artistas</h2>
      </div>

      <% if (artists.length === 0) { %>
        <div class="text-center py-5">
          <i class="bi bi-people fs-1 text-muted mb-3 d-block"></i>
          <p class="text-secondary mb-3">No estás siguiendo a ningún artista todavía.</p>
          <a href="/artists/search" class="btn btn-spotify"><i class="bi bi-search me-2"></i>Buscar en Last.fm</a>
        </div>
      <% } else { %>
        <div class="artist-grid">
          <% artists.forEach(artist => { %>
            <a href="/artists/<%= artist.id %>" class="text-decoration-none artist-grid-item" title="<%= artist.name %>">
              <div class="artist-card-square mb-2">
                <% if (artist.image) { %>
                  <img src="<%= artist.image %>" alt="<%= artist.name %>" class="artist-img-square">
                <% } else { %>
                  <div class="artist-img-square bg-secondary d-flex align-items-center justify-content-center text-dark">
                    <i class="bi bi-person-fill fs-2"></i>
                  </div>
                <% } %>
              </div>
              <div class="artist-name-text">
                <%= artist.name %>
              </div>
            </a>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</div>

<style>
  /* Grilla de 8 columnas en monitores grandes */
  .artist-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  @media (min-width: 576px) {
    .artist-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (min-width: 768px) {
    .artist-grid {
      grid-template-columns: repeat(6, 1fr);
    }
  }

  @media (min-width: 1200px) {
    .artist-grid {
      grid-template-columns: repeat(8, 1fr);
    }
  }

  .artist-grid-item {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Tarjeta cuadrada 1:1 */
  .artist-card-square {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--glass-border);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .artist-card-square:hover {
    transform: scale(1.06);
    box-shadow: 0 8px 25px rgba(229, 9, 20, 0.25);
    border-color: rgba(229, 9, 20, 0.4);
  }

  .artist-img-square {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Nombre abajo de la imagen */
  .artist-name-text {
    color: #f8f9fa;
    font-weight: 600;
    font-size: 0.85rem;
    margin-top: 4px;
    text-align: center;
    width: 100%;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.2s ease;
  }

  .artist-grid-item:hover .artist-name-text {
    color: var(--brand-color);
  }
</style>

<%- include('partials/footer') %>
