<%- include('partials/header') %>



<div class="row">
  <div class="col-12">
    <div class="glass-card p-4">
      <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <h2 class="h4 fw-bold m-0 d-flex align-items-center gap-2">
          <i class="bi bi-music-note-list text-danger"></i>
          <span>Tus Artistas</span>
          <% if (artists.length > 0) { %>
            <span id="artistsCountBadge" class="badge bg-secondary-subtle text-secondary-emphasis rounded-pill fs-6 fw-normal"><%= artists.length %></span>
          <% } %>
        </h2>
        <% if (artists.length > 0) { %>
          <div class="d-flex gap-2 flex-wrap" style="max-width: 500px; width: 100%;">
            <!-- Selector de Países -->
            <div class="position-relative flex-grow-1" style="max-width: 200px;">
              <select id="countryFilter" class="form-select form-select-sm rounded-pill text-white px-3" style="cursor: pointer; font-size: 0.85rem; height: 31px; background-color: var(--glass-bg); border-color: var(--glass-border); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">
                <option value="" style="background-color: #212529; color: #fff;">Todos los países</option>
              </select>
            </div>
            <!-- Campo de Búsqueda -->
            <div class="position-relative flex-grow-1" style="max-width: 250px;">
              <span class="position-absolute top-50 start-0 translate-middle-y ps-3 text-secondary">
                <i class="bi bi-funnel"></i>
              </span>
              <input type="text" id="filterInput" class="form-control form-control-sm rounded-pill text-white ps-5" style="background-color: var(--glass-bg); border-color: var(--glass-border); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);" placeholder="Filtrar artistas..." autocomplete="off">
            </div>
          </div>
        <% } %>
      </div>

      <% if (artists.length === 0) { %>
        <div class="text-center py-5">
          <i class="bi bi-people fs-1 text-muted mb-3 d-block"></i>
          <p class="text-secondary mb-3">No estás siguiendo a ningún artista todavía.</p>
          <a href="/artists/search" class="btn btn-spotify"><i class="bi bi-search me-2"></i>Buscar en Last.fm</a>
        </div>
      <% } else { %>
        <div class="artist-grid">
          <% artists.forEach(artist => { %>
            <% 
              let artistMeta = {};
              if (artist.metadata) {
                try {
                  artistMeta = JSON.parse(artist.metadata);
                } catch(e) {}
              }
              const locationStr = artistMeta['Lugar de nacimiento'] || artistMeta['Formado en'];
              const flagPath = getFlagPath(locationStr);
              let countryCode = '';
              if (flagPath) {
                countryCode = flagPath.split('/').pop().replace('.png', '');
              }
            %>
            <a href="/artists/<%= encodeURIComponent(artist.id) %>" class="text-decoration-none artist-grid-item" title="<%= artist.name %>" data-country="<%= countryCode %>">
              <div class="artist-card-square mb-2">
                <% if (artist.image) { %>
                  <img src="<%= artist.image %>" alt="<%= artist.name %>" class="artist-img-square">
                <% } else { %>
                  <div class="artist-img-square bg-secondary d-flex align-items-center justify-content-center text-dark">
                    <i class="bi bi-person-fill fs-2"></i>
                  </div>
                <% } %>
                <% if (flagPath) { %>
                  <div class="position-absolute" style="bottom: 8px; right: 8px; z-index: 10;">
                    <div class="d-flex align-items-center justify-content-center border border-danger border-1 rounded-circle shadow" style="width: 32px; height: 32px; background-color: rgba(0, 0, 0, 0.65);" title="<%= artistMeta['Lugar de nacimiento'] || artistMeta['Formado en'] %>">
                      <img src="<%= flagPath %>" alt="Bandera" class="rounded-circle" style="width: 20px; height: 20px; object-fit: cover;" />
                    </div>
                  </div>
                <% } %>
              </div>
              <div class="artist-name-text">
                <%= artist.name %>
              </div>
            </a>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</div>

<% if (artists.length > 0) { %>
  <!-- Abecedario flotante en pantallas medianas y grandes -->
  <div class="alphabet-sidebar d-none d-md-flex flex-column align-items-center gap-1 py-3 px-2 rounded-pill shadow-lg" style="position: fixed; right: 16px; top: 52%; transform: translateY(-50%); z-index: 1050; background-color: rgba(33, 37, 41, 0.55); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.08); max-height: 85vh; overflow: visible;">
    <% 
      const alphabetStr = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
      alphabetStr.split("").forEach(letter => { 
    %>
      <button class="btn btn-link text-decoration-none p-0 d-flex align-items-center justify-content-center alphabet-indicator fw-bold text-center" 
              data-letter="<%= letter %>" 
              style="width: 18px; height: 18px; font-size: 0.7rem; border-radius: 50%; transition: all 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275); cursor: pointer; position: relative;">
        <%= letter %>
      </button>
    <% }) %>
  </div>
<% } %>

<style>
  /* Grilla de 8 columnas en monitores grandes */
  .artist-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  @media (min-width: 576px) {
    .artist-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (min-width: 768px) {
    .artist-grid {
      grid-template-columns: repeat(6, 1fr);
    }
  }

  @media (min-width: 1200px) {
    .artist-grid {
      grid-template-columns: repeat(8, 1fr);
    }
  }

  .artist-grid-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 0;
    width: 100%;
  }

  /* Tarjeta cuadrada 1:1 */
  .artist-card-square {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--glass-border);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .artist-card-square:hover {
    transform: scale(1.06);
    box-shadow: 0 8px 25px rgba(229, 9, 20, 0.25);
    border-color: rgba(229, 9, 20, 0.4);
  }

  .artist-img-square {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Nombre abajo de la imagen */
  .artist-name-text {
    color: #f8f9fa;
    font-weight: 600;
    font-size: 0.85rem;
    margin-top: 4px;
    text-align: center;
    width: 100%;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.2s ease;
  }

  .artist-grid-item:hover .artist-name-text {
    color: var(--brand-color);
  }
  #filterInput:focus {
    border-color: var(--brand-color) !important;
    box-shadow: 0 0 0 0.25rem rgba(229, 9, 20, 0.25) !important;
    background-color: rgba(0, 0, 0, 0.7) !important;
  }

  /* Estilos para el abecedario flotante */
  .alphabet-sidebar::-webkit-scrollbar {
    width: 0;
    background: transparent;
  }
  .alphabet-indicator {
    color: rgba(255, 255, 255, 0.75) !important;
    background-color: transparent;
  }
  .alphabet-indicator:hover {
    background-color: rgba(229, 9, 20, 0.75) !important;
    color: #ffffff !important;
    transform: scale(3);
    z-index: 10;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.4);
  }
  .alphabet-indicator.active-letter {
    background-color: rgba(229, 9, 20, 0.75) !important;
    color: #ffffff !important;
  }
  .alphabet-indicator.disabled {
    opacity: 0.15;
    cursor: not-allowed;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filterInput = document.getElementById('filterInput');
    const countryFilter = document.getElementById('countryFilter');
    const artistItems = document.querySelectorAll('.artist-grid-item');    const countryNames = {
      'estadosunidos': 'Estados Unidos',
      'reinounido': 'Reino Unido',
      'alemania': 'Alemania',
      'espana': 'España',
      'francia': 'Francia',
      'suecia': 'Suecia',
      'noruega': 'Noruega',
      'finlandia': 'Finlandia',
      'dinamarca': 'Dinamarca',
      'belgica': 'Bélgica',
      'paisesbajos': 'Países Bajos',
      'brasil': 'Brasil',
      'japon': 'Japón',
      'canada': 'Canadá',
      'australia': 'Australia',
      'nuevazelandia': 'Nueva Zelanda',
      'italia': 'Italia',
      'china': 'China',
      'bosniaherzegovina': 'Bosnia y Herzegovina',
      'argentina': 'Argentina',
      'uruguay': 'Uruguay',
      'chile': 'Chile',
      'mexico': 'México',
      'colombia': 'Colombia',
      'rumania': 'Rumanía',
      'panama': 'Panamá',
      'peru': 'Perú',
      'monaco': 'Mónaco',
      'islandia': 'Islandia',
      'republicadominicana': 'República Dominicana',
      'republicacheca': 'República Checa',
      'sudafrica': 'Sudáfrica',
      'turquia': 'Turquía',
      'camerun': 'Camerún',
      'letonia': 'Letonia',
      'singapur': 'Singapur',
      'federacionrusa': 'Federación Rusa',
      'barbados': 'Barbados',
      'cuba': 'Cuba',
      'jamaica': 'Jamaica',
      'puertorico': 'Puerto Rico',
      'suiza': 'Suiza',
      'nigeria': 'Nigeria',
      'serbia': 'Serbia',
      'tanzania': 'Tanzania',
      'irlanda': 'Irlanda'
    };

    // Crear el mensaje de "no hay resultados"
    const noResultsMsg = document.createElement('div');
    noResultsMsg.id = 'noResultsMsg';
    noResultsMsg.className = 'text-center py-5 d-none';
    noResultsMsg.innerHTML = `
      <i class="bi bi-search fs-2 text-muted mb-2 d-block"></i>
      <p class="text-secondary m-0">No se encontraron artistas que coincidan con la búsqueda.</p>
    `;
    
    const grid = document.querySelector('.artist-grid');
    if (grid) {
      grid.parentNode.appendChild(noResultsMsg);
    }

    const countryFlags = {
      'estadosunidos': '🇺🇸',
      'reinounido': '🇬🇧',
      'alemania': '🇩🇪',
      'espana': '🇪🇸',
      'francia': '🇫🇷',
      'suecia': '🇸🇪',
      'noruega': '🇳🇴',
      'finlandia': '🇫🇮',
      'dinamarca': '🇩🇰',
      'belgica': '🇧🇪',
      'paisesbajos': '🇳🇱',
      'brasil': '🇧🇷',
      'japon': '🇯🇵',
      'canada': '🇨🇦',
      'australia': '🇦🇺',
      'nuevazelandia': '🇳🇿',
      'italia': '🇮🇹',
      'china': '🇨🇳',
      'bosniaherzegovina': '🇧🇦',
      'argentina': '🇦🇷',
      'uruguay': '🇺🇾',
      'chile': '🇨🇱',
      'mexico': '🇲🇽',
      'colombia': '🇨🇴',
      'rumania': '🇷🇴',
      'panama': '🇵🇦',
      'peru': '🇵🇪',
      'monaco': '🇲🇨',
      'islandia': '🇮🇸',
      'republicadominicana': '🇩🇴',
      'republicacheca': '🇨🇿',
      'sudafrica': '🇿🇦',
      'turquia': '🇹🇷',
      'camerun': '🇨🇲',
      'letonia': '🇱🇻',
      'singapur': '🇸🇬',
      'federacionrusa': '🇷🇺',
      'barbados': '🇧🇧',
      'cuba': '🇨🇺',
      'jamaica': '🇯🇲',
      'puertorico': '🇵🇷',
      'suiza': '🇨🇭',
      'nigeria': '🇳🇬',
      'serbia': '🇷🇸',
      'tanzania': '🇹🇿',
      'irlanda': '🇮🇪'
    };

    // Inicializar dinámicamente las opciones del selector de países
    if (countryFilter) {
      const uniqueCountries = {};
      let noCountryCount = 0;
      artistItems.forEach(item => {
        const country = item.getAttribute('data-country');
        if (country) {
          uniqueCountries[country] = (uniqueCountries[country] || 0) + 1;
        } else {
          noCountryCount++;
        }
      });

      const sortedCountries = Object.keys(uniqueCountries).sort((a, b) => {
        const countA = uniqueCountries[a];
        const countB = uniqueCountries[b];
        if (countB !== countA) {
          return countB - countA; // Mayor cantidad primero
        }
        const nameA = countryNames[a] || a.toUpperCase();
        const nameB = countryNames[b] || b.toUpperCase();
        return nameA.localeCompare(nameB, 'es', { sensitivity: 'base' }); // Empate alfabético
      });

      sortedCountries.forEach(code => {
        const option = document.createElement('option');
        option.value = code;
        option.style.backgroundColor = '#212529';
        option.style.color = '#ffffff';
        const flag = countryFlags[code] || '🏳️';
        const name = countryNames[code] || code.charAt(0).toUpperCase() + code.slice(1);
        const count = uniqueCountries[code];
        option.textContent = `${flag} ${name} (${count})`;
        countryFilter.appendChild(option);
      });

      if (noCountryCount > 0) {
        const option = document.createElement('option');
        option.value = 'no_country';
        option.style.backgroundColor = '#212529';
        option.style.color = '#ffffff';
        option.textContent = `🏳️ Sin datos (${noCountryCount})`;
        countryFilter.appendChild(option);
      }
    }

    function cleanText(str) {
      if (!str) return '';
      return str.toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/ñ/g, 'n');
    }

    function filterArtists() {
      const query = filterInput ? filterInput.value.toLowerCase().trim() : '';
      const selectedCountry = countryFilter ? countryFilter.value : '';
      let visibleCount = 0;

      const cleanQuery = cleanText(query);

      artistItems.forEach(item => {
        const name = item.querySelector('.artist-name-text').textContent;
        const cleanName = cleanText(name);
        const country = item.getAttribute('data-country');

        const matchesQuery = cleanName.includes(cleanQuery);
        let matchesCountry = false;
        if (!selectedCountry) {
          matchesCountry = true;
        } else if (selectedCountry === 'no_country') {
          matchesCountry = !country || country === '';
        } else {
          matchesCountry = country === selectedCountry;
        }

        if (matchesQuery && matchesCountry) {
          item.classList.remove('d-none');
          visibleCount++;
        } else {
          item.classList.add('d-none');
        }
      });

      if (visibleCount === 0) {
        if (grid) grid.classList.add('d-none');
        noResultsMsg.classList.remove('d-none');
      } else {
        if (grid) grid.classList.remove('d-none');
        noResultsMsg.classList.add('d-none');
      }

      const badge = document.getElementById('artistsCountBadge');
      if (badge) {
        badge.textContent = visibleCount;
      }

      // Actualizar qué letras del abecedario están disponibles
      updateAlphabetState();
    }

    // Lógica del abecedario flotante
    function getCleanInitial(str) {
      if (!str) return '';
      return str.trim().charAt(0).toUpperCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/ñ/g, 'n');
    }

    function updateAlphabetState() {
      const visibleInitials = new Set();
      artistItems.forEach(item => {
        if (!item.classList.contains('d-none')) {
          const name = item.querySelector('.artist-name-text').textContent;
          const initial = getCleanInitial(name);
          if (initial) visibleInitials.add(initial);
        }
      });

      document.querySelectorAll('.alphabet-indicator').forEach(indicator => {
        const letter = indicator.getAttribute('data-letter');
        if (visibleInitials.has(letter)) {
          indicator.classList.remove('disabled');
          indicator.style.pointerEvents = 'auto';
        } else {
          indicator.classList.add('disabled');
          indicator.style.pointerEvents = 'none';
        }
      });
    }

    // Inicializar estado del abecedario
    updateAlphabetState();

    // Event listeners para saltar a letras
    document.querySelectorAll('.alphabet-indicator').forEach(indicator => {
      indicator.addEventListener('click', (e) => {
        e.preventDefault();
        const letter = indicator.getAttribute('data-letter');
        const targetItem = Array.from(artistItems).find(item => {
          if (item.classList.contains('d-none')) return false;
          const name = item.querySelector('.artist-name-text').textContent;
          return getCleanInitial(name) === letter;
        });

        if (targetItem) {
          targetItem.scrollIntoView({ behavior: 'smooth', block: 'center' });
          
          // Efecto de parpadeo temporal de realce para indicar visualmente dónde saltó
          targetItem.style.transition = 'outline 0.3s ease';
          targetItem.style.outline = '2px solid var(--brand-color)';
          targetItem.style.borderRadius = '12px';
          
          setTimeout(() => {
            targetItem.style.outline = '2px solid transparent';
          }, 1500);
        }
      });
    });

    if (filterInput) {
      filterInput.addEventListener('input', filterArtists);
    }
    if (countryFilter) {
      countryFilter.addEventListener('change', filterArtists);
    }
  });
</script>

<%- include('partials/footer') %>
