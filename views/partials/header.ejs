<!DOCTYPE html>
<html lang="es" data-bs-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | MusicTracker</title>
  <!-- Favicon Emoji Inline -->
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22><%= typeof faviconEmoji !== 'undefined' ? faviconEmoji : '🎵' %></text></svg>">
  
  <!-- Google Fonts: Outfit -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  
  <!-- Bootstrap 5.3 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
  
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  
  <style>
    :root {
      --brand-color: #e50914;
      --glass-bg: rgba(33, 37, 41, 0.75);
      --glass-border: rgba(255, 255, 255, 0.08);
      --accent-gradient: linear-gradient(135deg, #e50914 0%, #ff1f2f 100%);
      --body-font: 'Outfit', sans-serif;
    }
    
    body {
      font-family: var(--body-font);
      background-color: #0b0a0a;
      color: #f8f9fa;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .glass-card {
      background: var(--glass-bg);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--glass-border);
      border-radius: 16px;
      box-shadow: 0 8px 30px 0 rgba(0, 0, 0, 0.37);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .glass-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 40px 0 rgba(229, 9, 20, 0.15);
      border-color: rgba(229, 9, 20, 0.2);
    }

    .navbar-glass {
      background: rgba(11, 10, 10, 0.85);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--glass-border);
    }

    .btn-spotify {
      background: var(--accent-gradient);
      border: none;
      color: #fff;
      font-weight: 600;
      border-radius: 50px;
      padding: 0.5rem 1.5rem;
      transition: all 0.2s ease;
    }

    .btn-spotify:hover {
      background: linear-gradient(135deg, #ff1f2f 0%, #ff5252 100%);
      transform: scale(1.03);
      color: #fff;
    }

    .text-gradient {
      background: var(--accent-gradient);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    a:focus-visible, button:focus-visible, input:focus-visible, select:focus-visible, textarea:focus-visible {
      outline: 3px solid var(--brand-color) !important;
      outline-offset: 2px;
    }
  </style>
</head>
<body>

  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark navbar-glass sticky-top py-3">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center fw-extrabold fs-4" href="/">
        <span class="me-2 fs-3">🎵</span> Music<span class="text-gradient">Tracker</span>
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto align-items-center">
          <li class="nav-item">
            <a class="nav-link px-3 <%= title === 'Dashboard' ? 'active text-danger fw-bold' : '' %>" href="/"><i class="bi bi-house-door me-1"></i>Inicio</a>
          </li>
          <li class="nav-item">
            <a class="nav-link px-3 <%= title === 'Buscar Artistas' ? 'active text-danger fw-bold' : '' %>" href="/artists/search"><i class="bi bi-search me-1"></i>Buscar Last.fm</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <main class="container my-5 flex-grow-1">
