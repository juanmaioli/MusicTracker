<%- include('partials/header') %>

<div class="row g-4">
  <!-- Título principal -->
  <div class="col-12">
    <div class="glass-card p-4 d-flex justify-content-between align-items-center flex-wrap gap-3">
      <div>
        <h1 class="h3 fw-bold m-0"><i class="bi bi-bar-chart-line text-danger me-2"></i>Estadísticas de tu Colección</h1>
        <p class="text-secondary m-0 mt-1 small">Métricas detalladas y gestión de copias de seguridad.</p>
      </div>
      <!-- Botones de Backup/Restore en la cabecera para acceso rápido -->
      <div class="d-flex align-items-center gap-2">
        <a href="/stats/backup" class="btn btn-sm btn-spotify d-flex align-items-center gap-1" title="Descargar copia de seguridad en formato tar.gz con imágenes">
          <i class="bi bi-download"></i> Respaldar
        </a>
        <label for="restoreFile" class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1 m-0 cursor-pointer" title="Subir archivo tar.gz para restaurar">
          <i class="bi bi-upload"></i> Restaurar
        </label>
        <input type="file" id="restoreFile" accept=".tar.gz" class="d-none">
      </div>
    </div>
  </div>

  <!-- Fila de métricas clave -->
  <div class="col-12">
    <div class="row g-3">
      <div class="col-6 col-md-3">
        <div class="glass-card p-3 text-center">
          <i class="bi bi-people-fill text-danger fs-3 mb-1 d-block"></i>
          <span class="d-block text-secondary small fw-semibold">Artistas</span>
          <span class="fs-3 fw-bold text-white"><%= totalArtists %></span>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="glass-card p-3 text-center">
          <i class="bi bi-disc-fill text-danger fs-3 mb-1 d-block"></i>
          <span class="d-block text-secondary small fw-semibold">Álbumes</span>
          <span class="fs-3 fw-bold text-white"><%= totalAlbums %></span>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="glass-card p-3 text-center">
          <i class="bi bi-music-note fs-3 mb-1 d-block" style="color: #ffc107;"></i>
          <span class="d-block text-secondary small fw-semibold">Canciones</span>
          <span class="fs-3 fw-bold text-white"><%= totalTracks %></span>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="glass-card p-3 text-center">
          <i class="bi bi-heart-fill text-danger fs-3 mb-1 d-block animate-pulse"></i>
          <span class="d-block text-secondary small fw-semibold">Favoritas</span>
          <span class="fs-3 fw-bold text-white"><%= totalFavorites %></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Métricas Avanzadas -->
  <div class="col-md-4">
    <div class="glass-card p-4 h-100">
      <h2 class="h5 fw-bold mb-3 d-flex align-items-center gap-2">
        <i class="bi bi-activity text-danger"></i>
        <span>Métricas Clave</span>
      </h2>
      <ul class="list-group list-group-flush list-group-dark bg-transparent">
        <li class="list-group-item bg-transparent text-white border-secondary border-opacity-10 px-0 d-flex justify-content-between align-items-center">
          <span class="text-secondary">Calificación promedio:</span>
          <span class="fw-semibold">
            <% if (avgAlbumRating !== 'N/A') { %>
              <i class="bi bi-star-fill text-warning me-1"></i><%= avgAlbumRating %>
            <% } else { %>
              <%= avgAlbumRating %>
            <% } %>
          </span>
        </li>
        <li class="list-group-item bg-transparent text-white border-secondary border-opacity-10 px-0 d-flex justify-content-between align-items-center">
          <span class="text-secondary">Tracks por Álbum:</span>
          <span class="fw-semibold"><%= avgTracksPerAlbum %></span>
        </li>
        <li class="list-group-item bg-transparent text-white border-secondary border-opacity-10 px-0 d-flex justify-content-between align-items-center">
          <span class="text-secondary">Tiempo de reproducción:</span>
          <span class="fw-semibold"><i class="bi bi-clock me-1 text-secondary"></i><%= totalDurationStr %></span>
        </li>
      </ul>
    </div>
  </div>

  <!-- Top 5 Géneros -->
  <div class="col-md-4">
    <div class="glass-card p-4 h-100">
      <h2 class="h5 fw-bold mb-3 d-flex align-items-center gap-2">
        <i class="bi bi-tags-fill text-danger"></i>
        <span>Géneros Populares</span>
      </h2>
      <% if (topGenres.length === 0) { %>
        <p class="text-secondary small py-3 text-center">No hay géneros registrados.</p>
      <% } else { %>
        <div class="d-flex flex-column gap-2 mt-2">
          <% topGenres.forEach((g, idx) => { %>
            <div class="d-flex align-items-center justify-content-between bg-dark bg-opacity-25 p-2 rounded border border-secondary border-opacity-10">
              <span class="small text-white-50"><span class="text-danger fw-bold me-1">#<%= idx + 1 %></span> <%= g.name %></span>
              <span class="badge bg-secondary rounded-pill text-white small"><%= g.count %> <%= g.count === 1 ? 'artista' : 'artistas' %></span>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Décadas -->
  <div class="col-md-4">
    <div class="glass-card p-4 h-100">
      <h2 class="h5 fw-bold mb-3 d-flex align-items-center gap-2">
        <i class="bi bi-calendar3 text-danger"></i>
        <span>Álbumes por Década</span>
      </h2>
      <% if (decades.length === 0) { %>
        <p class="text-secondary small py-3 text-center">No hay datos de lanzamiento.</p>
      <% } else { %>
        <div class="d-flex flex-column gap-2 mt-2">
          <% decades.forEach(d => { %>
            <div class="d-flex align-items-center justify-content-between bg-dark bg-opacity-25 p-2 rounded border border-secondary border-opacity-10">
              <span class="small text-white-50"><i class="bi bi-calendar-event me-2 text-secondary"></i> Década del <%= d.decade %>s</span>
              <span class="badge bg-danger rounded-pill text-white small"><%= d.count %> <%= d.count === 1 ? 'álbum' : 'álbumes' %></span>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Top 5 Álbumes Mejor Calificados -->
  <div class="col-12">
    <div class="glass-card p-4">
      <h2 class="h5 fw-bold mb-3 d-flex align-items-center gap-2">
        <i class="bi bi-trophy-fill text-warning"></i>
        <span>Top 5 Álbumes Mejor Calificados</span>
      </h2>
      <% if (topAlbums.length === 0) { %>
        <p class="text-secondary small py-4 text-center">Calificá tus álbumes para verlos en este podio.</p>
      <% } else { %>
        <div class="table-responsive">
          <table class="table table-dark table-hover table-borderless align-middle m-0 small">
            <thead>
              <tr class="text-secondary border-bottom border-secondary border-opacity-10">
                <th scope="col" style="width: 50px;">#</th>
                <th scope="col">Título</th>
                <th scope="col">Artista</th>
                <th scope="col" class="text-center" style="width: 100px;">Año</th>
                <th scope="col" class="text-end" style="width: 180px;">Calificación</th>
              </tr>
            </thead>
            <tbody>
              <% topAlbums.forEach((al, index) => { %>
                <tr class="hover-track-row">
                  <td class="text-danger fw-bold"><%= index + 1 %></td>
                  <td class="fw-semibold text-white"><%= al.title %></td>
                  <td class="text-white-50"><%= al.artist_name %></td>
                  <td class="text-center text-secondary"><%= al.release_year || '—' %></td>
                  <td class="text-end">
                    <div class="d-inline-flex gap-1" style="user-select: none;" title="Calificación: <%= al.user_rating %> estrellas">
                      <% for (let i = 1; i <= 5; i++) { %>
                        <span style="color: <%= i <= al.user_rating ? '#ffc107' : '#6c757d' %>;">
                          <%= i <= al.user_rating ? '★' : '☆' %>
                        </span>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Gestión de Base de Datos y Backup/Restauración -->
  <div class="col-12">
    <div class="glass-card p-4 mb-4">
      <h2 class="h5 fw-bold mb-3 d-flex align-items-center gap-2">
        <i class="bi bi-database-fill-gear text-danger"></i>
        <span>Mantenimiento de Datos</span>
      </h2>
      <div class="row g-3">
        <!-- Tarjeta de Descargar Backup -->
        <div class="col-md-4">
          <div class="bg-dark bg-opacity-25 p-3 rounded-4 border border-secondary border-opacity-10 d-flex align-items-start gap-3 h-100">
            <div class="bg-danger bg-opacity-10 p-2.5 rounded-3 text-danger fs-4">
              <i class="bi bi-cloud-arrow-down-fill"></i>
            </div>
            <div>
              <h3 class="h6 fw-bold text-white mb-1">Exportar Copia</h3>
              <p class="text-secondary small mb-3">Generá y descargá un archivo comprimido .tar.gz con toda tu colección y sus imágenes locales.</p>
              <a href="/stats/backup" class="btn btn-sm btn-spotify d-inline-flex align-items-center gap-1">
                <i class="bi bi-download"></i> Descargar tar.gz
              </a>
            </div>
          </div>
        </div>
        <!-- Tarjeta de Restaurar Backup -->
        <div class="col-md-4">
          <div class="bg-dark bg-opacity-25 p-3 rounded-4 border border-secondary border-opacity-10 d-flex align-items-start gap-3 h-100">
            <div class="bg-warning bg-opacity-10 p-2.5 rounded-3 text-warning fs-4">
              <i class="bi bi-cloud-arrow-up-fill"></i>
            </div>
            <div>
              <h3 class="h6 fw-bold text-white mb-1">Restaurar Copia</h3>
              <p class="text-secondary small mb-3"><span class="text-warning fw-semibold">¡Atención!</span> Esto reemplazará la colección e imágenes actuales con las del archivo .tar.gz.</p>
              <label for="restoreFileSecondary" class="btn btn-sm btn-outline-warning d-inline-flex align-items-center gap-1 m-0 cursor-pointer">
                <i class="bi bi-upload"></i> Seleccionar y Restaurar
              </label>
              <input type="file" id="restoreFileSecondary" accept=".tar.gz" class="d-none">
            </div>
          </div>
        </div>
        <!-- Tarjeta de Importación Batch TXT -->
        <div class="col-md-4">
          <div class="bg-dark bg-opacity-25 p-3 rounded-4 border border-secondary border-opacity-10 d-flex align-items-start gap-3 h-100">
            <div class="bg-info bg-opacity-10 p-2.5 rounded-3 text-info fs-4">
              <i class="bi bi-file-earmark-text-fill"></i>
            </div>
            <div>
              <h3 class="h6 fw-bold text-white mb-1">Importar en Lote (.txt)</h3>
              <p class="text-secondary small mb-3">Subí un archivo de texto con nombres de artistas (uno por línea). Se esperarán 15 segundos entre cada uno.</p>
              <label for="batchFile" class="btn btn-sm btn-outline-info d-inline-flex align-items-center gap-1 m-0 cursor-pointer">
                <i class="bi bi-file-plus"></i> Seleccionar TXT
              </label>
              <input type="file" id="batchFile" accept=".txt" class="d-none">
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .cursor-pointer {
    cursor: pointer;
  }
  .hover-track-row:hover {
    background-color: rgba(255, 255, 255, 0.02) !important;
  }
  .animate-pulse {
    display: inline-block;
    animation: pulse 2s infinite ease-in-out;
  }
  @keyframes pulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.1); }
    100% { transform: scale(1); }
  }
</style>

<!-- Modal de Carga de Restauración -->
<div class="modal fade" id="restoreLoadingModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content bg-dark border-secondary border-opacity-25 text-white rounded-4 shadow">
      <div class="modal-body text-center p-4">
        <div class="spinner-border text-danger mb-3" role="status" style="width: 3rem; height: 3rem;">
          <span class="visually-hidden">Restaurando...</span>
        </div>
        <h5 class="fw-bold">Restaurando Copia de Seguridad</h5>
        <p class="text-secondary small m-0">Por favor, no cierres el navegador ni detengas el servidor...</p>
      </div>
    </div>
  </div>
</div>

<!-- Modal de Progreso de Importación Batch -->
<div class="modal fade" id="batchModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="batchModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
    <div class="modal-content bg-dark border-secondary border-opacity-25 text-white rounded-4 shadow-lg">
      <div class="modal-header border-bottom border-secondary border-opacity-10 py-3">
        <h5 class="modal-title fw-bold" id="batchModalLabel">
          <i class="bi bi-file-earmark-arrow-up text-info me-2"></i>Importación en Lote
        </h5>
        <button type="button" class="btn-close btn-close-white" id="batchCloseBtn" data-bs-dismiss="modal" aria-label="Cerrar" disabled></button>
      </div>
      <div class="modal-body p-4">
        <!-- Barra de progreso e info principal -->
        <div class="text-center mb-4">
          <div class="d-flex justify-content-between mb-2">
            <span id="batchProgressText" class="text-secondary small fw-semibold">Procesando: 0 / 0</span>
            <span id="batchPercentText" class="text-info small fw-bold">0%</span>
          </div>
          <div class="progress bg-secondary bg-opacity-25 rounded-pill" style="height: 10px;">
            <div id="batchProgressBar" class="progress-bar bg-info progress-bar-striped progress-bar-animated rounded-pill" role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
          </div>
          <!-- Contador de cuenta regresiva de 15 segundos -->
          <div id="batchCountdownContainer" class="mt-3 text-secondary small fw-medium" style="display: none;">
            Próximo artista en: <span id="batchCountdown" class="text-info fw-bold fs-5">15</span> segundos...
          </div>
        </div>

        <!-- Lista de artistas con estado de procesamiento -->
        <h6 class="fw-bold mb-3 d-flex align-items-center gap-2">
          <i class="bi bi-list-task text-secondary"></i>
          <span>Listado y Estados</span>
        </h6>
        <div class="table-responsive style-scrollbar" style="max-height: 250px; overflow-y: auto;">
          <table class="table table-dark table-hover table-borderless align-middle m-0 small">
            <thead>
              <tr class="text-secondary border-bottom border-secondary border-opacity-10">
                <th scope="col">Artista</th>
                <th scope="col" class="text-end" style="width: 180px;">Estado</th>
              </tr>
            </thead>
            <tbody id="batchTableBody">
              <!-- Filas dinámicas -->
            </tbody>
          </table>
        </div>
      </div>
      <div class="modal-footer border-top border-secondary border-opacity-10 py-3">
        <button type="button" class="btn btn-secondary btn-sm" id="batchDoneBtn" data-bs-dismiss="modal" disabled>Listo</button>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Lógica de Restauración
    const restoreInput = document.getElementById('restoreFile');
    const restoreInputSec = document.getElementById('restoreFileSecondary');
    const loadingModal = new bootstrap.Modal(document.getElementById('restoreLoadingModal'));

    async function handleRestore(file) {
      if (!file) return;

      const confirmAction = confirm('¿Estás seguro de que querés restaurar los datos? Esta acción eliminará y reemplazará por completo la colección actual.');
      if (!confirmAction) return;

      loadingModal.show();

      const reader = new FileReader();
      reader.onload = async (evt) => {
        try {
          const base64Data = evt.target.result.split(',')[1];
          
          const response = await fetch('/stats/restore', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({ archive: base64Data })
          });

          const result = await response.json();
          
          setTimeout(() => {
            loadingModal.hide();
            if (result.success) {
              alert('Copia de seguridad restaurada correctamente. La página se recargará.');
              window.location.reload();
            } else {
              alert('Error al restaurar los datos: ' + result.error);
            }
          }, 1000);
        } catch (err) {
          loadingModal.hide();
          alert('El archivo seleccionado no es un respaldo de copia de seguridad válido.');
        }
      };

      reader.onerror = () => {
        loadingModal.hide();
        alert('Error al leer el archivo.');
      };

      reader.readAsDataURL(file);
    }

    restoreInput.addEventListener('change', (e) => handleRestore(e.target.files[0]));
    restoreInputSec.addEventListener('change', (e) => handleRestore(e.target.files[0]));

    // Lógica de Importación en Lote (Batch)
    const batchInput = document.getElementById('batchFile');
    const batchModal = new bootstrap.Modal(document.getElementById('batchModal'));
    const batchTableBody = document.getElementById('batchTableBody');
    const batchProgressText = document.getElementById('batchProgressText');
    const batchPercentText = document.getElementById('batchPercentText');
    const batchProgressBar = document.getElementById('batchProgressBar');
    const batchCountdownContainer = document.getElementById('batchCountdownContainer');
    const batchCountdown = document.getElementById('batchCountdown');
    const batchDoneBtn = document.getElementById('batchDoneBtn');
    const batchCloseBtn = document.getElementById('batchCloseBtn');

    batchInput.addEventListener('change', async (e) => {
      const file = e.target.files[0];
      if (!file) return;

      const reader = new FileReader();
      reader.onload = async (evt) => {
        const text = evt.target.result;
        const artists = text.split('\n')
          .map(line => line.trim())
          .filter(line => line.length > 0);

        if (artists.length === 0) {
          alert('El archivo TXT está vacío.');
          return;
        }

        // Resetear interfaz del modal
        batchTableBody.innerHTML = '';
        batchProgressText.textContent = `Procesando: 0 / ${artists.length}`;
        batchPercentText.textContent = '0%';
        batchProgressBar.style.width = '0%';
        batchProgressBar.setAttribute('aria-valuenow', '0');
        batchCountdownContainer.style.display = 'none';
        batchDoneBtn.disabled = true;
        batchCloseBtn.disabled = true;

        // Crear filas en la tabla del modal
        const rows = {};
        artists.forEach((name, idx) => {
          const tr = document.createElement('tr');
          tr.className = 'hover-track-row';
          tr.innerHTML = `
            <td class="text-white-50">${name}</td>
            <td class="text-end text-secondary fw-semibold" id="batch-row-${idx}">En espera...</td>
          `;
          batchTableBody.appendChild(tr);
          rows[idx] = document.getElementById(`batch-row-${idx}`);
        });

        // Mostrar modal de progreso
        batchModal.show();

        // Limpiar archivo input para permitir subir el mismo archivo después
        batchInput.value = '';

        // Procesar secuencialmente
        for (let i = 0; i < artists.length; i++) {
          const name = artists[i];
          const rowEl = rows[i];

          // Cambiar estado a "Importando..."
          rowEl.innerHTML = '<span class="spinner-border spinner-border-sm text-info me-1" role="status"></span> Importando...';
          batchProgressText.textContent = `Procesando: ${i + 1} / ${artists.length}`;

          try {
            const response = await fetch('/artists/batch-add', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify({ name })
            });

            const result = await response.json();
            if (response.ok && result.success) {
              if (result.alreadyExists) {
                rowEl.innerHTML = '<span class="text-secondary"><i class="bi bi-info-circle me-1"></i> Ya en colección</span>';
              } else {
                rowEl.innerHTML = '<span class="text-success"><i class="bi bi-check-circle-fill me-1"></i> Importado</span>';
              }
            } else {
              rowEl.innerHTML = `<span class="text-danger" title="${result.error || 'Fallo'}"><i class="bi bi-exclamation-triangle-fill me-1"></i> No encontrado</span>`;
            }
          } catch (err) {
            rowEl.innerHTML = '<span class="text-danger"><i class="bi bi-x-circle-fill me-1"></i> Error de red</span>';
          }

          // Actualizar barra de progreso
          const percent = Math.round(((i + 1) / artists.length) * 100);
          batchPercentText.textContent = `${percent}%`;
          batchProgressBar.style.width = `${percent}%`;
          batchProgressBar.setAttribute('aria-valuenow', percent);

          // Si no es el último elemento, esperar 15 segundos
          if (i < artists.length - 1) {
            batchCountdownContainer.style.display = 'block';
            let secondsLeft = 15;
            batchCountdown.textContent = secondsLeft;

            while (secondsLeft > 0) {
              await new Promise(resolve => setTimeout(resolve, 1000));
              secondsLeft--;
              batchCountdown.textContent = secondsLeft;
            }
            batchCountdownContainer.style.display = 'none';
          }
        }

        // Habilitar cierre y finalización
        batchDoneBtn.disabled = false;
        batchCloseBtn.disabled = false;
      };
      reader.readAsText(file);
    });
  });
</script>

<%- include('partials/footer') %>
